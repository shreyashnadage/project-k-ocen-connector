      "unique": 1,
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "sector",
      "fieldtype": "Data",
      "label": "Sector"
    },
    {
      "fieldname": "region",
      "fieldtype": "Data",
      "label": "Region"
    },
    {
      "fieldname": "section_platform",
      "fieldtype": "Section Break",
      "label": "Platform Sync"
    },
    {
      "fieldname": "platform_anchor_id",
      "fieldtype": "Data",
      "label": "Platform Anchor ID",
      "read_only": 1
    },
    {
      "fieldname": "repayment_routing_active",
      "fieldtype": "Check",
      "label": "Repayment Routing Active",
      "default": 0,
      "in_list_view": 1
