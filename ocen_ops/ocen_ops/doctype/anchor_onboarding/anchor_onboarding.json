      "read": 1,
      "write": 1,
      "create": 1,
      "report": 1
    },
    {
      "role": "OCEN Ops Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "report": 1
    },
    {
      "role": "OCEN Ops Viewer",
      "read": 1,
      "report": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
